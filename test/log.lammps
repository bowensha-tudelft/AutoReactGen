units           real
atom_style      full
newton          on

boundary        p p p
dimension       3

# ── Force field: preserve BCD-MDI system terms ────────────────
bond_style      hybrid harmonic
angle_style     hybrid harmonic
dihedral_style  hybrid multi/harmonic charmm
special_bonds   lj 0.0 0.0 0.5 coul 0.0 0.0 0.8333

pair_style      lj/cut/coul/dsf 0.25 9.0 9.0
pair_modify     tail yes mix arithmetic

read_data       primary_core.data                           extra/bond/per/atom      5                           extra/angle/per/atom     15                          extra/dihedral/per/atom  20                          extra/special/per/atom   30
